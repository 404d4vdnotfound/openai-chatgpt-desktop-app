prefix_rule(
    pattern = ["pnpm", "test"],
    decision = "allow",
    justification = "Project validation"
)

prefix_rule(
    pattern = ["pnpm", "typecheck"],
    decision = "allow",
    justification = "Project validation"
)

prefix_rule(
    pattern = ["pnpm", "lint"],
    decision = "allow",
    justification = "Project validation"
)

prefix_rule(
    pattern = ["pnpm", "build"],
    decision = "allow",
    justification = "Project validation"
)

prefix_rule(
    pattern = ["npm", "test"],
    decision = "allow",
    justification = "Project validation"
)

prefix_rule(
    pattern = ["npm", "run"],
    decision = "allow",
    justification = "Project validation and package scripts"
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Read-only repo inspection"
)

prefix_rule(
    pattern = ["git", "diff"],
    decision = "allow",
    justification = "Read-only repo inspection"
)

prefix_rule(
    pattern = ["git", "log"],
    decision = "allow",
    justification = "Read-only repo inspection"
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Destructive recursive delete. Use targeted removal after inspection."
)
